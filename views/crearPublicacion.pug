extends layout

block content
    form.row.g-3(method="POST" action="/publicaciones/crear")
        .col-12
            label.form-label(for="inputTitulo") Título
            input.form-control(type="text" id="inputTitulo" name="titulo" placeholder="Título de la publicación", required)

        .col-12
            label.form-label(for="inputDescripcion") Descripción
            textarea.form-control(id="inputDescripcion" name="descripcion" rows="5" placeholder="Escribe aquí el contenido de tu publicación...", required)

        .col-12
            label.form-label(for="inputUrl") URL de la imagen 1
            input.form-control(type="url" id="inputUrl" name="url" placeholder="https://ejemplo.com/imagen1.jpg")

        .col-12
            label.form-label(for="inputUrl1") URL de la imagen 2
            input.form-control(type="url" id="inputUrl1" name="url1" placeholder="https://ejemplo.com/imagen2.jpg")

        .col-12
            label.form-label(for="inputUrl2") URL de la imagen 3
            input.form-control(type="url" id="inputUrl2" name="url2" placeholder="https://ejemplo.com/imagen3.jpg")

        .col-12
            label.form-label(for="inputLicencia") Tipo de licencia
            select.form-control(id="inputLicencia" name="licencia" required)
                option(value="") Selecciona...
                option(value="copyright") Copyright (todos los derechos reservados)
                option(value="sin_copyright") Sin copyright (dominio público / libre)

        .col-12(id="campoMarcaAgua" style="display: none;")
            label.form-label(for="inputMarcaAgua") Marca de agua
            input.form-control(type="text" id="inputMarcaAgua" name="marca_agua" placeholder="Ej: © MiEmpresa 2024")

        .col-12
            label.form-label(for="inputEtiquetas") Etiquetas
            input.form-control(
                type="text" 
                id="inputEtiquetas" 
                name="etiquetas" 
                placeholder="paisaje, noche, urbano, naturaleza..."
            )
            .help-text Separa las etiquetas con comas (ej: tecnologia, programacion, web)

        .col-12
            button.btn.btn-primary(type="submit") Publicar

        .col-12
            a(href="/perfil") Volver a mi perfil

    script.
        const licenciaSelect = document.getElementById('inputLicencia');
        const campoMarcaAgua = document.getElementById('campoMarcaAgua');

        licenciaSelect.addEventListener('change', function() {
            if (this.value === 'copyright') {
                campoMarcaAgua.style.display = 'block';
            } else {
                campoMarcaAgua.style.display = 'none';
            }
        });