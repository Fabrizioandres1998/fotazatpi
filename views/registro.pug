doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title Registrarse
        link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet")

    body.bg-light
        .container.mt-5
            .row.justify-content-center
                .col-md-8.col-lg-6
                    .card.shadow
                        .card-header.bg-success.text-white.text-center
                            h3.mb-0 Registrarse

                        .card-body
                            if error
                                .alert.alert-danger(role="alert")
                                    | #{error}

                            form(method="POST" action="/registro")
                                .mb-3
                                    label.form-label(for="inputNombre") Nombre de usuario
                                    input.form-control(type="text" id="inputNombre" name="username" placeholder="Ej: juanperez123" required)

                                .mb-3
                                    label.form-label(for="inputEmail") Correo electrónico
                                    input.form-control(type="email" id="inputEmail" name="email" placeholder="correo@ejemplo.com" required)

                                .mb-3
                                    label.form-label(for="inputPassword") Contraseña
                                    input.form-control(type="password" id="inputPassword" name="password_hash" placeholder="Minimo 6 caracteres" required)

                                .mb-3
                                    label.form-label(for="inputConfirmPassword") Confirmar contraseña
                                    input.form-control(type="password" id="inputConfirmPassword" name="confirmPassword" placeholder="Repite tu contraseña" required)

                                button.btn.btn-success.w-100(type="submit") Registrarse

                                hr

                                .text-center
                                    p.mb-0
                                        | ¿Ya tenes cuenta? 
                                        a(href="/login") Inicia sesión acá

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
    script.
        const password = document.getElementById('inputPassword');
        const confirmPassword = document.getElementById('inputConfirmPassword');

        confirmPassword.addEventListener('keyup', function() {
            if (password.value !== this.value) {
                this.setCustomValidity('Las contraseñas no coinciden');
            } else {
                this.setCustomValidity('');
            }
        });