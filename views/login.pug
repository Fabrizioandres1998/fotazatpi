doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Iniciar Sesión
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet")

  body.bg-light
    .container.mt-5
      .row.justify-content-center
        .col-md-6.col-lg-4
          .card.shadow
            .card-header.bg-primary.text-white.text-center
              h3.mb-0 Iniciar Sesión

            .card-body
              if error
                .alert.alert-danger(role="alert")
                  | #{error}

              form(method="POST" action="/login")
                .mb-3
                  label.form-label(for="email") Correo electronico
                  input.form-control(type="email" id="email" name="email" placeholder="correo@ejemplo.com" required)

                .mb-3
                  label.form-label(for="password") Contraseña
                  input.form-control(type="password" id="password" name="password_hash" placeholder="Tu contraseña" required)

                button.btn.btn-primary.w-100(type="submit") Iniciar Sesión

                hr

                .text-center
                  p.mb-0
                    | ¿No tenes cuenta? 
                    a(href="/registro") Registrate aca

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")