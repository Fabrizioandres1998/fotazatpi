doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title Document
    body 
        h1= title
        form(method="POST" action="/login")
            div
                label Email:
                input(type="email" name="email" required)
            div
                label Contraseña:
                input(type="password" name="password" required)
            button(type="submit") Ingresar